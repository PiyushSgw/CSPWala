# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database (Production: Render ke Database_URL use karo) ───────────────────
# Render me DATABASE_URL environment variable se milega
DATABASE_URL=postgres://user:password@host:port/dbname

# Agar local ke liye separate keys chahiye to niche ke lines ko uncomment karo
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=csp_passbook_db
# DB_USER=postgres
# DB_PASSWORD=your_local_db_password
# DB_POOL_MAX=20
# DB_POOL_IDLE_TIMEOUT=30000

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_prod_jwt_access_secret_here
JWT_REFRESH_SECRET=your_prod_jwt_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ADMIN JWT
ADMIN_JWT_SECRET=your_prod_admin_jwt_secret_here

# ─── AWS S3 / Cloudflare R2 ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_prod_aws_access_key
AWS_SECRET_ACCESS_KEY=your_prod_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=csp-passbook-bucket
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# ─── OTP – MSG91 ──────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=your_prod_msg91_auth_key
MSG91_TEMPLATE_ID=your_prod_msg91_template_id
MSG91_SENDER_ID=CSPPBK

# ─── OTP – Fast2SMS (fallback) ────────────────────────────────────────────────
FAST2SMS_API_KEY=your_prod_fast2sms_api_key

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_prod_email@gmail.com
SMTP_PASS=your_prod_email_password
EMAIL_FROM=noreply@csppassbook.com

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@csppassbook.com
ADMIN_PASSWORD=your_prod_admin_password

# ─── Wallet ───────────────────────────────────────────────────────────────────
PASSBOOK_PRINT_CHARGE=10
FREE_REPRINT_WINDOW_HOURS=2

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=CSP Passbook Portal
APP_URL=https://csp-passbook-backend.onrender.com
FRONTEND_URL=https://csp-passbook-frontend.onrender.com

# ─── Rate Limiting ────────────────────────────────────────────────────────────
OTP_RATE_LIMIT_WINDOW_MS=900000
OTP_RATE_LIMIT_MAX=5
RECHARGE_RATE_LIMIT_WINDOW_MS=3600000
RECHARGE_RATE_LIMIT_MAX=10